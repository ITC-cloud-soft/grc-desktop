{
  "name": "grc-server",
  "version": "0.1.0",
  "description": "WinClaw Global Resource Center — Modular Monolith API Server",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/shared/db/migrate.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build:desktop": "bash scripts/build-desktop.sh",
    "build:desktop:win": "scripts\\build-desktop.bat",
    "start:desktop": "node -e \"process.env.GRC_DB_DIALECT='sqlite'; require('child_process').execSync('node dist/index.js', {stdio:'inherit', env:{...process.env, GRC_DB_DIALECT:'sqlite'}})\"",
    "start:desktop:simple": "node dist/index.js"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "meilisearch": "^0.44.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.0",
    "mysql2": "^3.12.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-github2": "^1.2.0",
    "@types/passport-google-oauth20": "^2.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
